---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const sorted = posts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  return sorted.map((post, i) => ({
    params: { slug: post.id },
    props: {
      post,
      prev: sorted[i + 1] || null,
      next: sorted[i - 1] || null,
    },
  }));
}

const { post, prev, next } = Astro.props;
const { Content, headings } = await render(post);
const koBody = post.body
  ? post.body.replace(/<LangBlock lang="en">[\s\S]*?<\/LangBlock>/g, '').replace(/```[\s\S]*?```/g, '').replace(/import .*\n/g, '')
  : '';
const wordCount = koBody.split(/\s+/).filter(Boolean).length;
---
<PostLayout
  title={post.data.title}
  titleEn={post.data.title_en}
  date={post.data.date}
  tags={post.data.tags}
  excerpt={post.data.excerpt}
  excerptEn={post.data.excerpt_en}
  headings={headings}
  prev={prev}
  next={next}
  wordCount={wordCount}
>
  <Content />
</PostLayout>
