---
interface Post {
  id: string;
  data: {
    title: string;
    date: string;
    tags: string[];
    excerpt: string;
  };
  body?: string;
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

const byYear: Record<string, Post[]> = {};
for (const p of posts) {
  const y = p.data.date.slice(0, 4);
  (byYear[y] ??= []).push(p);
}
const years = Object.keys(byYear).sort().reverse();
---

{years.map(year => (
  <div class="year-group">
    <div class="year-header">
      <h2 class="year-title">{year}</h2>
      <span class="year-count">{byYear[year].length} posts</span>
    </div>
    {byYear[year].map(p => (
      <a href={`/posts/${p.id}`} class="post-row">
        <span class="post-date">{p.data.date.slice(5).replace('-', '.')}</span>
        <div class="post-main">
          <div class="post-tags">
            {p.data.tags.map(t => <span class="post-tag">#{t}</span>)}
          </div>
          <h3 class="post-title">{p.data.title}</h3>
          <p class="post-excerpt">{p.data.excerpt}</p>
        </div>
      </a>
    ))}
  </div>
))}

<style>
  .year-group { margin-bottom: 32px; }
  .year-header { display: flex; align-items: baseline; gap: 16px; margin-bottom: 20px; padding-bottom: 10px; border-bottom: 1px solid var(--border); }
  .year-title { font-size: 44px; font-weight: 300; letter-spacing: -0.04em; margin: 0; font-feature-settings: 'tnum'; }
  .year-count { font-size: 12px; color: var(--mute); }
  .post-row { display: grid; grid-template-columns: 72px 1fr; gap: 24px; align-items: baseline; padding: 22px 0; border-bottom: 1px solid var(--border-soft); color: inherit; text-decoration: none; }
  .post-row:hover .post-title { color: var(--accent); }
  .post-date { font-family: var(--font-mono); font-size: 12px; color: var(--sub); letter-spacing: 0.03em; padding-top: 4px; }
  .post-tags { display: flex; gap: 8px; font-size: 11px; color: var(--sub); margin-bottom: 6px; }
  .post-tag { color: var(--accent); }
  .post-title { font-size: 18px; font-weight: 500; line-height: 1.35; margin: 0 0 6px; transition: color 0.15s; }
  .post-excerpt { font-size: 14px; color: var(--sub); line-height: 1.6; margin: 0; }
</style>
