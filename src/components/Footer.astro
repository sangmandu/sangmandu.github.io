---
import VisitorCounter from './VisitorCounter.tsx';
---
<footer class="footer">
  <div class="footer-left">
    <span>&copy; 2026 sangmandu</span>
    <VisitorCounter client:idle />
  </div>
  <div class="footer-links">
    <a href="https://github.com/sangmandu">github</a>
    <a href="mailto:toxj17@gmail.com">email</a>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 24px 48px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12px;
    color: var(--sub);
    max-width: var(--max-width);
    margin: 48px auto 0;
  }
  .footer-left { display: flex; gap: 16px; align-items: center; }
  .footer-links { display: flex; gap: 16px; }
  .footer-links a { color: var(--sub); }
</style>
