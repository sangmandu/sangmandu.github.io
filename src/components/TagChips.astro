---
interface Props {
  tags: { name: string; count: number }[];
  active?: string;
}
const { tags, active } = Astro.props;
---
<div class="tag-chips-section">
  <div class="tag-chips-label">Filter by tag</div>
  <div class="tag-chips">
    {tags.map(t => (
      <a
        href={t.name === 'all' ? '/archive' : `/archive?tag=${t.name}`}
        class:list={['chip', { active: (active || 'all') === t.name }]}
      >
        {t.name} <span class="chip-count">{t.count}</span>
      </a>
    ))}
  </div>
</div>

<style>
  .tag-chips-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: var(--sub); margin-bottom: 12px; }
  .tag-chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .chip { padding: 5px 12px; border: 1px solid var(--border); border-radius: 999px; font-size: 12px; color: var(--text); background: transparent; }
  .chip:hover { border-color: var(--accent); }
  .chip.active { background: var(--accent); border-color: var(--accent); color: #fff; }
  .chip-count { color: var(--mute); margin-left: 4px; }
  .chip.active .chip-count { color: rgba(255,255,255,0.7); }
</style>
