<script>
  function applyLang(lang: string) {
    document.querySelectorAll('.lang-block').forEach(el => {
      if (el.classList.contains(`lang-${lang}`)) {
        el.classList.add('lang-active');
      } else {
        el.classList.remove('lang-active');
      }
    });
  }

  const stored = localStorage.getItem('lang') || 'ko';
  applyLang(stored);

  window.addEventListener('lang-change', (e: Event) => {
    applyLang((e as CustomEvent).detail);
  });
</script>

<style is:global>
  .lang-block { display: none !important; }
  .lang-block.lang-active { display: revert !important; }
</style>
