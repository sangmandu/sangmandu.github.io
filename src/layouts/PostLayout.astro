---
import BaseLayout from './BaseLayout.astro';
import PrevNext from '../components/PrevNext.astro';
import Comments from '../components/Comments.astro';
import PostTitle from '../components/PostTitle.tsx';
import DynamicTOC from '../components/DynamicTOC.tsx';
import WordCount from '../components/WordCount.tsx';

interface Props {
  title: string;
  titleEn?: string;
  date: string;
  tags: string[];
  excerpt: string;
  excerptEn?: string;
  headings: { depth: number; slug: string; text: string }[];
  prev?: { id: string; data: { title: string; title_en?: string } };
  next?: { id: string; data: { title: string; title_en?: string } };
  wordCountKo: number;
  wordCountEn: number;
}

const { title, titleEn, date, tags, excerpt, excerptEn, headings, prev, next, wordCountKo, wordCountEn } = Astro.props;
const readMin = Math.max(1, Math.ceil(wordCountKo / 200));
---
<BaseLayout title={title}>
  <div class="post-grid">
    <div class="post-back">
      <a href="/" class="back-link">← back</a>
    </div>
    <article class="post-article">
      <div class="post-meta">
        <span>{date}</span>
        <span>·</span>
        {tags.map(t => <span class="meta-tag">#{t}</span>)}
        <span>·</span>
        <span>{readMin} min</span>
        <span>·</span>
        <WordCount client:load ko={wordCountKo} en={wordCountEn} />
      </div>
      <PostTitle
        client:load
        title={title}
        titleEn={titleEn}
        excerpt={excerpt}
        excerptEn={excerptEn}
      />
      <div class="prose">
        <slot />
      </div>
      <PrevNext prev={prev} next={next} />
      <Comments />
    </article>
    <aside class="post-toc">
      <DynamicTOC client:load />
    </aside>
  </div>
</BaseLayout>

<style>
  .post-grid {
    display: grid;
    grid-template-columns: 72px minmax(0, 620px) 180px;
    gap: 28px;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 48px 32px 96px;
    justify-content: center;
  }
  .post-back { font-size: 13px; }
  .back-link { position: sticky; top: 100px; color: var(--sub); white-space: nowrap; }
  .back-link:hover { color: var(--text); }
  .post-meta { display: flex; gap: 12px; font-size: 12px; color: var(--sub); font-family: var(--font-mono); margin-bottom: 18px; }
  .meta-tag { color: var(--accent); }
</style>
