---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import PrevNext from '../components/PrevNext.astro';

interface Props {
  title: string;
  date: string;
  tags: string[];
  excerpt: string;
  headings: { depth: number; slug: string; text: string }[];
  prev?: { id: string; data: { title: string } };
  next?: { id: string; data: { title: string } };
  wordCount: number;
}

const { title, date, tags, excerpt, headings, prev, next, wordCount } = Astro.props;
const readMin = Math.max(1, Math.ceil(wordCount / 200));
---
<BaseLayout title={title}>
  <div class="post-grid">
    <div class="post-back">
      <a href="/" class="back-link">← back</a>
    </div>
    <article class="post-article">
      <div class="post-meta">
        <span>{date}</span>
        <span>·</span>
        {tags.map(t => <span class="meta-tag">#{t}</span>)}
        <span>·</span>
        <span>{readMin} min</span>
        <span>·</span>
        <span>{wordCount.toLocaleString()} words</span>
      </div>
      <h1 class="post-title">{title}</h1>
      <p class="post-excerpt">{excerpt}</p>
      <div class="prose">
        <slot />
      </div>
      <PrevNext prev={prev} next={next} />
    </article>
    <aside class="post-toc">
      <TOC headings={headings} />
    </aside>
  </div>
</BaseLayout>

<style>
  .post-grid {
    display: grid;
    grid-template-columns: 72px minmax(0, 620px) 180px;
    gap: 28px;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 48px 32px 96px;
    justify-content: center;
  }
  .post-back { font-size: 13px; }
  .back-link { position: sticky; top: 100px; color: var(--sub); white-space: nowrap; }
  .back-link:hover { color: var(--text); }
  .post-meta { display: flex; gap: 12px; font-size: 12px; color: var(--sub); font-family: var(--font-mono); margin-bottom: 18px; }
  .meta-tag { color: var(--accent); }
  .post-title { font-size: 40px; font-weight: 500; letter-spacing: -0.025em; line-height: 1.15; margin: 0 0 16px; }
  .post-excerpt { font-size: 19px; line-height: 1.55; color: var(--sub); margin: 0 0 40px; font-style: italic; }
</style>
